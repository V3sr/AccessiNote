NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Backend CORS for local development.
# Leave blank to use the backend default local origins, or set explicitly:
# ACCESSINOTE_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
ACCESSINOTE_CORS_ORIGINS=

# Runtime provider editing.
# Keep "enabled" so the /settings page can accept session-scoped user keys.
# Use "disabled" only when provider values should come from backend environment variables.
ACCESSINOTE_RUNTIME_PROVIDER_SETTINGS=enabled

# Provider defaults. Local fallback remains available when Azure is not configured.
TRANSCRIPTION_PROVIDER=local
OCR_PROVIDER=local
GENERATION_PROVIDER=local

# Optional Microsoft/Azure providers.
# Put real values only in a private .env file, never in the public repo or demo video.
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=
AZURE_SPEECH_LANGUAGE=en-US
AZURE_VISION_ENDPOINT=
AZURE_VISION_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=
