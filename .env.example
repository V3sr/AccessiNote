NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Backend CORS. Add the production frontend URL after deployment.
# Example: ACCESSINOTE_CORS_ORIGINS=https://accessinote.vercel.app
ACCESSINOTE_CORS_ORIGINS=

# Runtime provider editing. Use "disabled" for public deployments that use backend-owned keys.
ACCESSINOTE_RUNTIME_PROVIDER_SETTINGS=enabled

# Provider defaults. Local fallback remains available when Azure is not configured.
TRANSCRIPTION_PROVIDER=local
OCR_PROVIDER=local
GENERATION_PROVIDER=local

# Optional Microsoft/Azure providers.
# Put real values only in a private .env file, never in the public repo or demo video.
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=
AZURE_SPEECH_LANGUAGE=en-US
AZURE_VISION_ENDPOINT=
AZURE_VISION_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=
